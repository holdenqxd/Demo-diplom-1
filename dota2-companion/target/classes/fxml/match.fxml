<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dota2companion.ui.MatchController">

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <VBox styleClass="card" spacing="12">
                <Label text="Детали матча" style="-fx-font-size: 16px; -fx-font-weight: 600;" />
                <TableView fx:id="scoreboardTable" prefHeight="250">
                    <columns>
                        <TableColumn text="Игрок" fx:id="playerColumn"/>
                        <TableColumn text="Герой" fx:id="heroColumn"/>
                        <TableColumn text="Убийства" fx:id="killsColumn"/>
                        <TableColumn text="Смерти" fx:id="deathsColumn"/>
                        <TableColumn text="Помощи" fx:id="assistsColumn"/>
                        <TableColumn text="ЗМ/мин" fx:id="gpmColumn"/>
                        <TableColumn text="ОП/мин" fx:id="xpmColumn"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="card" spacing="12">
                <Label text="Чистое золото по времени" style="-fx-font-size: 16px; -fx-font-weight: 600;" />
                <LineChart fx:id="netWorthChart" prefHeight="250">
                    <xAxis>
                        <NumberAxis label="Время (мин)"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Чистое золото"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <VBox styleClass="card" spacing="12">
                <Label text="Хронология убийств" style="-fx-font-size: 16px; -fx-font-weight: 600;" />
                <LineChart fx:id="killTimelineChart" prefHeight="250">
                    <xAxis>
                        <NumberAxis label="Время (мин)"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Убийства"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </VBox>
    </center>

</BorderPane>

